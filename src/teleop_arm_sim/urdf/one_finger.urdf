<?xml version="1.0"?>
<robot name="one_finger_arm">

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.02"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
  </link>

  <joint name="finger_joint0" type="revolute">
    <parent link="base_link"/>
    <child link="finger_base"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.1" upper="0.1" effort="1" velocity="1"/>
  </joint>

  <link name="finger_base" />

  <joint name="finger_joint1" type="revolute">
    <parent link="finger_base"/>
    <child link="finger_seg1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.2" upper="1.5" effort="1" velocity="1"/>
  </joint>

  <link name="finger_seg1">
    <visual>
      <geometry>
        <box size="0.015 0.015 0.05"/>
      </geometry>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <material name="green">
        <color rgba="0 1 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="finger_joint2" type="revolute">
    <parent link="finger_seg1"/>
    <child link="finger_seg2"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="1.5" effort="1" velocity="1"/>
  </joint>

  <link name="finger_seg2">
    <visual>
      <geometry>
        <box size="0.015 0.015 0.03"/>
      </geometry>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <material name="green">
        <color rgba="0 1 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="finger_joint3" type="revolute">
    <parent link="finger_seg2"/>
    <child link="finger_seg3"/>
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="1.5" effort="1" velocity="1"/>
  </joint>

  <link name="finger_seg3">
    <visual>
      <geometry>
        <box size="0.015 0.015 0.025"/>
      </geometry>
      <origin xyz="0 0 0.0125" rpy="0 0 0"/>
      <material name="green">
        <color rgba="0 1 0 1"/>
      </material>
    </visual>
  </link>

</robot>